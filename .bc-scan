{
  "ignore": [
    {
      "postconditionId": "missing-form-provider",
      "path": "components/Account/ArtistInstructionTextArea.tsx",
      "reason": "Component is designed for optional FormProvider use via the hookToForm prop (defaults false). useFormContext() must be called unconditionally per React Rules of Hooks. All downstream usage is null-guarded via isFullyHooked check and the useEffect formContext guard."
    },
    {
      "postconditionId": "missing-form-provider",
      "path": "components/Input.tsx",
      "reason": "Same pattern as ArtistInstructionTextArea — optional FormProvider via hookToForm prop. useFormContext() call is unconditional per Rules of Hooks; all usage is null-guarded."
    }
  ]
}
